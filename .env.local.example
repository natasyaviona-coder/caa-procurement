# Copy this file to `.env.local` and fill in the values from your Supabase project.
# Project settings → API in the Supabase dashboard.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Server-only key. NEVER expose to the browser. Used only by scripts/admin routes
# (e.g. creating the initial admin user). Leave blank until you actually need it.
SUPABASE_SERVICE_ROLE_KEY=
